# Copy to .env and fill in. .env is gitignored — never commit it.

# ===== LLM Provider selection =====
# Which backend to use:
#   "gemini"    — Google Gemini (cloud, needs GOOGLE_API_KEY)
#   "llamacpp"  — local Ollama server (needs Ollama running)
#   "hf"        — Hugging Face Inference API (for HF Spaces deploys, needs HF token)
LLM_PROVIDER=gemini

# ===== Google Gemini (cloud) =====
# Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ===== Local LLM via Ollama (llama.cpp under the hood) =====
# Start Ollama with: ollama serve (or it autostarts on macOS)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:31b

# ===== Hugging Face Inference (for HF Spaces / hosted demos) =====
# Get a token at https://huggingface.co/settings/tokens (the free "Read" token works)
HUGGINGFACEHUB_API_TOKEN=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# Optional: route via a specific inference backend (together, fireworks-ai, etc.)
HF_PROVIDER=

# ===== Langfuse observability =====
# Free cloud tier: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ===== Mem0 (cross-session memory) =====
# Hosted: https://app.mem0.ai
MEM0_API_KEY=
